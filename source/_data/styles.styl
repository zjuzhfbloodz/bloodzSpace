:root
  --bs-bg: #ffffff
  --bs-paper: #f7f9fb
  --bs-ink: #111317
  --bs-text: #2f343b
  --bs-muted: #757d88
  --bs-line: #e5e9ef
  --bs-line-strong: #cbd2dc
  --bs-red: #b72c35
  --bs-cyan: #dff5fa
  --bs-blue: #315d7d
  --bs-shadow: 0 24px 80px rgba(17, 19, 23, 0.08)
  --bs-radius: 8px
  --bs-max: 1160px

html
  background: var(--bs-bg)
  scroll-behavior: smooth

body
  color: var(--bs-text)
  background:
    linear-gradient(90deg, rgba(17,19,23,0.035) 1px, transparent 1px) 0 0 / 72px 72px,
    linear-gradient(180deg, rgba(17,19,23,0.028) 1px, transparent 1px) 0 0 / 72px 72px,
    var(--bs-bg)
  font-family: "Avenir Next", "Inter", "PingFang SC", "Noto Sans SC", sans-serif
  letter-spacing: 0

body::before
  content: ""
  position: fixed
  inset: 0
  pointer-events: none
  z-index: -1
  background:
    linear-gradient(110deg, transparent 0 48%, rgba(223,245,250,0.7) 48% 58%, transparent 58%),
    radial-gradient(680px 360px at 90% 8%, rgba(183,44,53,0.08), transparent 70%)

a
  color: var(--bs-ink)
  text-decoration-color: rgba(183,44,53,0.28)
  text-underline-offset: 0.18em

a:hover
  color: var(--bs-red)
  text-decoration-color: var(--bs-red)

.headband
  display: none

.header
  background: rgba(255,255,255,0.9)
  border-bottom: 1px solid var(--bs-line)
  backdrop-filter: blur(18px)

.header-inner
  max-width: var(--bs-max)
  margin: 0 auto
  padding: 14px 0 12px

.site-brand-container
  display: flex
  align-items: baseline
  justify-content: space-between
  gap: 24px

.site-meta
  text-align: left

.brand
  color: var(--bs-ink)
  letter-spacing: 0
  background: none !important

.site-title
  display: inline
  font-family: Georgia, "Times New Roman", "Songti SC", serif
  font-weight: 700
  letter-spacing: 0
  color: var(--bs-ink) !important
  background: transparent !important
  padding: 0 !important

.site-subtitle
  color: var(--bs-muted)
  font-size: 13px
  margin: 2px 0 0

.logo-line-before,
.logo-line-after
  display: none

.menu .menu-item a
  border-radius: 0
  color: var(--bs-muted)
  font-size: 13px
  font-weight: 700
  letter-spacing: 0
  padding-inline: 8px
  transition: color 160ms ease, background-size 180ms ease
  background-image: linear-gradient(var(--bs-red), var(--bs-red))
  background-repeat: no-repeat
  background-position: 0 100%
  background-size: 0 1px

.menu .menu-item a:hover
  color: var(--bs-ink)
  background-color: transparent
  background-size: 100% 1px

.main-inner
  max-width: var(--bs-max)
  margin: 0 auto

.content-wrap
  background: transparent

.post-block,
.comments,
.tabs-comment
  border-radius: var(--bs-radius)
  border: 1px solid var(--bs-line)
  background: rgba(255,255,255,0.92)
  box-shadow: none

.use-motion .brand,
.use-motion .site-title,
.use-motion .site-subtitle,
.use-motion .menu-item,
.use-motion .post-block,
.use-motion .post-header,
.use-motion .post-body,
.use-motion .pagination,
.use-motion .comments,
.use-motion .collection-header
  opacity: 1 !important

.posts-expand .post-block
  padding: clamp(22px, 4vw, 42px)
  margin-bottom: 18px
  transition: border-color 180ms ease, transform 180ms ease, box-shadow 180ms ease

.posts-expand .post-block:hover
  border-color: var(--bs-line-strong)
  transform: translateY(-2px)
  box-shadow: var(--bs-shadow)

.post-title,
.posts-expand .post-title
  color: var(--bs-ink)
  font-family: Georgia, "Times New Roman", "Songti SC", serif
  font-weight: 700
  letter-spacing: 0

.posts-expand .post-title-link
  color: var(--bs-ink)
  background: none

.posts-expand .post-title-link:hover
  color: var(--bs-red)

.post-meta,
.post-meta a
  color: var(--bs-muted)
  font-size: 12px

.post-body
  color: var(--bs-text)
  font-size: 16px
  line-height: 1.88

.post-body h1,
.post-body h2,
.post-body h3
  color: var(--bs-ink)
  font-family: Georgia, "Times New Roman", "Songti SC", serif
  letter-spacing: 0

.post-body img
  width: min(100%, 760px)
  height: auto
  border-radius: var(--bs-radius)
  border: 1px solid var(--bs-line)

.post-button .btn,
.pagination .page-number,
.pagination .extend
  border-radius: 999px
  border-color: var(--bs-line)
  background: #fff

.post-button .btn:hover,
.pagination .page-number:hover,
.pagination .extend:hover
  border-color: var(--bs-red)
  color: var(--bs-red)

.posts-expand .post-eof
  display: none

.posts-collapse
  background: #fff
  border: 1px solid var(--bs-line)
  border-radius: var(--bs-radius)
  padding: 10px 16px

.posts-collapse .post-header
  border-bottom-color: var(--bs-line)

.posts-collapse .post-title a:hover
  color: var(--bs-red)

.collection-title h1,
.collection-title h2
  font-family: Georgia, "Times New Roman", "Songti SC", serif
  font-size: clamp(32px, 5vw, 58px)
  letter-spacing: 0

.footer
  color: var(--bs-muted)

.sidebar,
.sidebar-toggle,
.sidebar-dimmer
  display: none !important

.main
  padding-top: 42px
  padding-bottom: 48px

.main-inner
  display: block

.menu .fa,
.menu i,
.menu-item a i
  display: none !important

.site-nav
  margin-top: 8px

.post-block:has(.home-directory)
  padding: 0
  border: 0
  background: transparent

.post-block:has(.home-directory):hover
  transform: none
  box-shadow: none

.post-block:has(.home-directory) .post-header,
.post-block:has(.home-directory) + .breadcrumb,
.post-block:has(.home-directory) ~ .breadcrumb
  display: none

.post-body:has(.home-directory)
  margin: 0
  padding: 0

.home-directory
  display: grid
  gap: 22px

.home-hero
  min-height: auto
  display: grid
  grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr)
  gap: clamp(20px, 4vw, 54px)
  align-items: stretch
  border-top: 1px solid var(--bs-ink)
  border-bottom: 1px solid var(--bs-line)
  padding: clamp(36px, 6vw, 78px) 0 clamp(42px, 6vw, 86px)

.home-hero-copy
  display: flex
  flex-direction: column
  justify-content: center

.home-hero h1
  margin: 0
  color: var(--bs-ink)
  font-family: Georgia, "Times New Roman", "Songti SC", serif
  font-size: clamp(52px, 8vw, 98px)
  line-height: 0.92
  letter-spacing: 0

.home-subtitle
  max-width: 620px
  margin: 24px 0 0
  color: var(--bs-text)
  font-size: clamp(17px, 2vw, 22px)
  line-height: 1.75

.home-actions
  display: flex
  flex-wrap: wrap
  gap: 12px
  margin-top: 34px

.home-actions a
  min-height: 42px
  display: inline-flex
  align-items: center
  justify-content: center
  padding: 0 18px
  border: 1px solid var(--bs-ink)
  border-radius: 999px
  color: var(--bs-ink)
  text-decoration: none
  font-size: 13px
  font-weight: 800
  transition: transform 160ms ease, background 160ms ease, color 160ms ease

.home-actions a:first-child
  color: #fff
  background: var(--bs-ink)

.home-actions a:hover
  transform: translateY(-2px)
  color: #fff
  background: var(--bs-red)
  border-color: var(--bs-red)

.home-index
  align-self: center
  border-left: 1px solid var(--bs-line)
  padding-left: clamp(18px, 3vw, 34px)
  display: grid
  gap: 16px

.home-index-item
  display: grid
  grid-template-columns: 70px minmax(0, 1fr)
  gap: 14px
  padding-bottom: 16px
  border-bottom: 1px solid var(--bs-line)
  color: inherit
  text-decoration: none

.home-index-item:last-child
  border-bottom: 0

.home-index-item span
  color: var(--bs-red)
  font-size: 12px
  font-weight: 900
  text-transform: uppercase

.home-index-item h2
  margin: 0 0 6px
  color: var(--bs-ink)
  font-size: 19px
  line-height: 1.35

.home-index-item p
  margin: 0
  color: var(--bs-muted)
  font-size: 14px
  line-height: 1.65

.home-lanes
  display: grid
  grid-template-columns: minmax(0, 1.2fr) minmax(300px, 0.8fr)
  gap: 18px

.home-panel
  padding: clamp(20px, 3vw, 34px)
  border: 1px solid var(--bs-line)
  background: rgba(255,255,255,0.86)

.home-panel h2
  margin: 0 0 16px
  color: var(--bs-ink)
  font-family: Georgia, "Times New Roman", "Songti SC", serif
  font-size: clamp(26px, 3vw, 42px)
  letter-spacing: 0

.home-panel p
  color: var(--bs-muted)
  line-height: 1.75

.home-stream
  display: grid
  gap: 0

.home-row
  display: grid
  grid-template-columns: 120px minmax(0, 1fr)
  gap: 18px
  padding: 16px 0
  border-top: 1px solid var(--bs-line)
  color: inherit
  text-decoration: none

.home-row time
  color: var(--bs-muted)
  font-size: 13px

.home-row strong
  color: var(--bs-ink)
  font-size: 18px
  line-height: 1.35

.home-row:hover strong
  color: var(--bs-red)

.home-side
  display: grid
  gap: 18px

.home-note
  min-height: 180px
  border: 1px solid var(--bs-line)
  background: var(--bs-paper)
  padding: 20px
  color: inherit
  text-decoration: none
  position: relative
  overflow: hidden

.home-note::after
  content: ""
  position: absolute
  width: 160px
  height: 160px
  right: -76px
  bottom: -76px
  border: 1px solid rgba(183,44,53,0.38)
  transform: rotate(18deg)

.home-note span
  color: var(--bs-red)
  font-size: 12px
  font-weight: 900

.home-note h3
  margin: 10px 0 8px
  color: var(--bs-ink)
  font-size: 22px
  line-height: 1.3

.idea-media
  display: flex
  gap: 16px
  align-items: flex-start
  margin: 1.2em 0

.idea-media-images,
.idea-media-image
  flex: 0 0 auto
  width: min(32%, 260px)

.idea-media-images
  display: flex
  flex-direction: column
  gap: 10px

.idea-media-images .idea-media-image
  width: 100%

.idea-media-image img
  width: 100%
  height: auto
  border-radius: var(--bs-radius)

.idea-media-text
  flex: 1 1 auto
  min-width: 0
  line-height: 1.8

.ideas-feed
  display: grid
  gap: 14px

.idea-card
  border: 1px solid var(--bs-line)
  border-radius: var(--bs-radius)
  padding: 20px
  background: rgba(255,255,255,0.9)
  transition: transform 160ms ease, border-color 160ms ease

.idea-card:hover
  transform: translateY(-2px)
  border-color: var(--bs-line-strong)

.idea-card-header
  display: flex
  align-items: baseline
  justify-content: space-between
  gap: 10px
  margin-bottom: 10px

.idea-card-title
  margin: 0
  font-size: 23px
  line-height: 1.35

.idea-card-title-link
  color: var(--bs-ink)
  text-decoration: none

.idea-card-date
  color: var(--bs-muted)
  font-size: 12px
  white-space: nowrap

.idea-card-read
  font-size: 13px
  color: var(--bs-red)
  text-decoration: none
  font-weight: 800

.wb-wrap
  max-width: 1080px
  margin: 0 auto
  padding: 4px 0 24px

.wb-hero
  border-top: 1px solid var(--bs-ink)
  border-bottom: 1px solid var(--bs-line)
  padding: clamp(24px, 5vw, 56px) 0
  margin-bottom: 18px

.wb-hero h1
  margin: 0
  color: var(--bs-ink)
  font-family: Georgia, "Times New Roman", "Songti SC", serif
  font-size: clamp(40px, 6vw, 76px)
  line-height: 0.95
  letter-spacing: 0

.wb-meta
  margin-top: 12px
  color: var(--bs-muted)
  font-size: 14px

.wb-grid
  columns: 2 320px
  column-gap: 14px

.wb-card
  break-inside: avoid
  min-width: 0
  border: 1px solid var(--bs-line)
  border-radius: var(--bs-radius)
  padding: 16px
  margin: 0 0 14px
  background: rgba(255,255,255,0.92)
  transition: transform 160ms ease, border-color 160ms ease

.wb-card:hover
  transform: translateY(-2px)
  border-color: var(--bs-line-strong)

.wb-head
  display: grid
  gap: 8px
  margin-bottom: 10px

.wb-head h2
  margin: 0
  color: var(--bs-ink)
  font-family: Georgia, "Times New Roman", "Songti SC", serif
  font-size: 22px
  font-weight: 700
  line-height: 1.2
  letter-spacing: 0
  overflow-wrap: anywhere

.wb-phonetic
  width: fit-content
  max-width: 100%
  color: var(--bs-blue)
  background: var(--bs-cyan)
  border: 1px solid #c8e8ef
  padding: 3px 8px
  border-radius: 999px
  font-size: 12px

.wb-meanings
  display: flex
  flex-wrap: wrap
  gap: 8px
  margin-bottom: 10px

.wb-chip
  display: inline-block
  border-radius: 999px
  background: #fff
  border: 1px solid var(--bs-line)
  color: var(--bs-ink)
  padding: 4px 10px
  font-size: 12px
  font-weight: 800

.wb-example
  padding: 12px
  border-left: 2px solid var(--bs-red)
  background: var(--bs-paper)
  margin-bottom: 8px

.wb-en,
.wb-zh
  line-height: 1.65
  margin-bottom: 7px
  color: var(--bs-text)
  overflow-wrap: anywhere

.wb-link
  font-size: 12px
  color: var(--bs-red)
  text-decoration: none
  font-weight: 800

.wb-mark
  background: var(--bs-cyan)
  padding: 0 3px

.reveal
  opacity: 0
  transform: translateY(18px)
  transition: opacity 520ms ease, transform 520ms ease

.reveal.is-visible
  opacity: 1
  transform: translateY(0)

@media (prefers-reduced-motion: reduce)
  *,
  *::before,
  *::after
    animation-duration: 0.001ms !important
    transition-duration: 0.001ms !important
    scroll-behavior: auto !important

@media (max-width: 991px)
  .home-hero,
  .home-lanes
    grid-template-columns: 1fr
  .home-index
    border-left: 0
    padding-left: 0
  .main-inner,
  .header-inner
    max-width: calc(100% - 28px)

@media (max-width: 767px)
  .post-body
    font-size: 15px
  .home-hero
    min-height: 0
  .home-hero h1
    font-size: 48px
  .home-index-item,
  .home-row
    grid-template-columns: 1fr
    gap: 6px
  .idea-media
    display: block
  .idea-media-images,
  .idea-media-image
    width: 100%
    margin-bottom: 8px
  .idea-card-header
    display: block
  .wb-grid
    columns: 1
